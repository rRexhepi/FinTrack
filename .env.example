# Copy to `.env` and fill in real values. `.env` is gitignored.

# Django
# Generate a fresh key with: python get_secret.py
SECRET_KEY=replace-me
DEBUG=True
# Comma-separated list; Django requires this set (non-empty) when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres — EITHER set DATABASE_URL (preferred, Render/Heroku style)...
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# ...OR the split vars below for plain local dev:
DB_NAME=fintrack_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
